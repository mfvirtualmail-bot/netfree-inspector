{
  "manifest_version": 3,
  "name": "NetFree Inspector",
  "version": "1.3.0",
  "description": "גלה חסימות נט פרי בכל דף באחת — Instantly detect NetFree content filter blocks on any page",
  "permissions": [
    "webRequest",
    "tabs",
    "storage",
    "webNavigation"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "NetFree Inspector",
    "default_icon": {
      "16": "icons/icon16-green.png",
      "32": "icons/icon32-green.png",
      "48": "icons/icon48-green.png",
      "128": "icons/icon128-green.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "default-src 'self'; img-src 'self' https://netfree.link data:; style-src 'self' 'unsafe-inline'"
  }
}
